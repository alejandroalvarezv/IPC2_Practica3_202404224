@page "/Productos/Editar/{id:int}"
@model MiProyecto.Pages.Productos.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<h2>Editar Producto</h2>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Producto.Id" />

    <label>Nombre:</label>
    <input type="text" name="Nombre" value="@Model.Producto.Nombre" required /><br/>

    <label>Categoría:</label>
    <input type="text" name="Categoria" value="@Model.Producto.Categoria" /><br/>

    <label>Descripción:</label>
    <input type="text" name="Descripcion" value="@Model.Producto.Descripcion" /><br/>

    <label>Precio:</label>
    <input type="number" step="0.01" name="Precio" value="@Model.Producto.Precio" /><br/>

    <label>Cantidad en Stock:</label>
    <input type="number" name="CantidadStock" value="@Model.Producto.CantidadStock" /><br/>

    <label>Fecha de Vencimiento (opcional):</label>
    <input type="date" name="FechaVencimiento"
           value="@Model.Producto.FechaVencimiento?.ToString("yyyy-MM-dd")" /><br/>

    <br/>
    <button type="submit">Actualizar</button>
    <a href="/Productos">Cancelar</a>
</form>
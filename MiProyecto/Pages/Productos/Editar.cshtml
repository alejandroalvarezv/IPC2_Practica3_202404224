@page "/Productos/Editar/{id:int}"
@model MiProyecto.Pages.Productos.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4>Editar Producto</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" name="Id" value="@Model.Producto.Id" />
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" name="Nombre" class="form-control" value="@Model.Producto.Nombre" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoría</label>
                            <input type="text" name="Categoria" class="form-control" value="@Model.Producto.Categoria" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea name="Descripcion" class="form-control" rows="2">@Model.Producto.Descripcion</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text">Q</span>
                                <input type="number" step="0.01" name="Precio" class="form-control" value="@Model.Producto.Precio" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Cantidad en Stock</label>
                            <input type="number" name="CantidadStock" class="form-control" value="@Model.Producto.CantidadStock" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fecha de Vencimiento (opcional)</label>
                            <input type="date" name="FechaVencimiento" class="form-control"
                                   value="@Model.Producto.FechaVencimiento?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="d-flex justify-content-between">
                            <a href="/Productos" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Actualizar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>